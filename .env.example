# Okta OIDC Configuration
# Create a free dev org at developer.okta.com → Applications → Create App Integration
# Choose: OIDC - Web Application → Authorization Code flow
# Sign-in redirect URI: http://localhost:5000/authorization-code/callback

OKTA_DOMAIN=dev-xxxxxxxx.okta.com
OKTA_CLIENT_ID=0oaxxxxxxxxxxxxxxxxx
OKTA_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OKTA_API_TOKEN=00xxxxxx   # Needed for /register (user creation via API)

# Flask session secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret

# Database — defaults to SQLite locally; set to postgresql://... in production
DATABASE_URL=

# Set to 'development' locally, 'production' on Cloud Run
FLASK_ENV=development
